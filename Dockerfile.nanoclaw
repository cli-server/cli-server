ARG NANOCLAW_VERSION=agentserver-k8s-mode
# Cache bust: 2026-03-26-v2
FROM node:20-slim AS builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y git python3 make g++ && rm -rf /var/lib/apt/lists/*

# Clone from agentserver fork (includes no-container mode + weixin channel)
ARG NANOCLAW_VERSION
ENV PNPM_ALLOW_BUILD=better-sqlite3,esbuild
RUN npm install -g pnpm && \
    git clone --branch ${NANOCLAW_VERSION} --depth 1 \
    https://github.com/agentserver/nanoclaw.git . && \
    pnpm install --frozen-lockfile && pnpm run build && \
    cd container/agent-runner && pnpm install && pnpm run build

FROM node:20-slim

WORKDIR /app

# Install Claude Code CLI
RUN npm install -g pnpm @anthropic-ai/claude-code

# Copy built NanoClaw
COPY --from=builder /app /app

# NanoClaw data directories
RUN mkdir -p /app/store /app/groups /app/data

# Config injection entrypoint
COPY nanoclaw-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 3002

ENTRYPOINT ["/entrypoint.sh"]
CMD ["node", "dist/index.js"]
