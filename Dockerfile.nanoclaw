ARG NANOCLAW_VERSION=v1.2.42
FROM node:20-slim AS builder

WORKDIR /app

# Install build dependencies (python3 + make + g++ needed for better-sqlite3 native addon)
RUN apt-get update && apt-get install -y git python3 make g++ && rm -rf /var/lib/apt/lists/*

# Clone from agentserver fork (includes no-container mode + weixin channel)
ARG NANOCLAW_VERSION
RUN git clone --branch ${NANOCLAW_VERSION} --depth 1 \
    https://github.com/agentserver/nanoclaw.git . && \
    npm ci && npm run build && \
    cd container/agent-runner && npm install && npm run build

FROM node:20-slim

WORKDIR /app

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Copy built NanoClaw
COPY --from=builder /app /app

# Run as the built-in node user (UID 1000) to match init container's chown target.
# Claude Code refuses --dangerously-skip-permissions as root.

# NanoClaw data directories and .env file (owned by nanoclaw user)
RUN mkdir -p /app/store /app/groups /app/data && \
    touch /app/.env && \
    chown -R node:node /app/store /app/groups /app/data /app/.env

# Config injection entrypoint
COPY nanoclaw-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 3002

USER node

ENTRYPOINT ["/entrypoint.sh"]
CMD ["node", "dist/index.js"]
