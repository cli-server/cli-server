ARG NANOCLAW_VERSION=v1.2.42

# Stage 0: Build agentserver Go binary (for mcp-server subcommand)
FROM golang:1.26-alpine AS go-builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /agentserver ./cmd/agentserver-agent

FROM node:20-slim AS builder

WORKDIR /app

# Install build dependencies (python3 + make + g++ needed for better-sqlite3 native addon)
RUN apt-get update && apt-get install -y git python3 make g++ && rm -rf /var/lib/apt/lists/*

# Clone from agentserver fork (includes no-container mode + weixin channel)
ARG NANOCLAW_VERSION
RUN git clone --branch ${NANOCLAW_VERSION} --depth 1 \
    https://github.com/agentserver/nanoclaw.git . && \
    npm ci && npm run build && \
    cd container/agent-runner && npm install && npm run build

FROM node:20-slim

WORKDIR /app

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# agentserver binary (mcp-server subcommand for agent discovery + delegation)
COPY --from=go-builder /agentserver /usr/local/bin/agentserver

# Copy built NanoClaw
COPY --from=builder /app /app

# Replace the built-in node user with agent (same UID 1000) to match
# the other sandbox images and the init container's chown target.
RUN usermod -l agent -d /home/agent -m node && groupmod -n agent node

# NanoClaw data directories and .env file (owned by agent user)
RUN mkdir -p /app/store /app/groups /app/data && \
    touch /app/.env && \
    chown -R agent:agent /app/store /app/groups /app/data /app/.env

# Config injection entrypoint
COPY nanoclaw-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 3002

USER agent

ENTRYPOINT ["/entrypoint.sh"]
CMD ["node", "dist/index.js"]
