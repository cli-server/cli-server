# Stage 1: Build agentserver Go binary (for mcp-server subcommand)
FROM golang:1.22-alpine AS go-builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /agentserver ./cmd/agentserver-agent

# Stage 2: Claude Code cloud sandbox
FROM node:20-slim

# ttyd: lightweight web terminal server
RUN apt-get update && \
    apt-get install -y --no-install-recommends ttyd git ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# agentserver binary (mcp-server subcommand for agent discovery + delegation)
COPY --from=go-builder /agentserver /usr/local/bin/agentserver

# Entrypoint
COPY claudecode-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Agent user (UID 1000, matches K8s init container expectations)
RUN useradd -m -u 1000 -s /bin/bash agent
USER agent
WORKDIR /home/agent

EXPOSE 7681

ENTRYPOINT ["/entrypoint.sh"]
