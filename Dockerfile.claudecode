# Stage 1: Build agentserver Go binary (for mcp-server subcommand)
FROM golang:1.26-alpine AS go-builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /agentserver ./cmd/agentserver-agent

# Stage 2: Claude Code cloud sandbox
FROM node:20-slim

# System dependencies (git, ca-certificates) + ttyd from GitHub releases
# (ttyd is not in Debian bookworm default repos)
RUN apt-get update && \
    apt-get install -y --no-install-recommends git ca-certificates curl && \
    curl -fsSL https://github.com/tsl0922/ttyd/releases/download/1.7.7/ttyd.x86_64 -o /usr/local/bin/ttyd && \
    chmod +x /usr/local/bin/ttyd && \
    apt-get purge -y curl && apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# agentserver binary (mcp-server subcommand for agent discovery + delegation)
COPY --from=go-builder /agentserver /usr/local/bin/agentserver

# Entrypoint
COPY claudecode-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Agent user (UID 1000, matches K8s init container expectations).
# node:20-slim already has a 'node' user at UID 1000 — reuse it with a login shell.
RUN usermod -l agent -d /home/agent -m -s /bin/bash node 2>/dev/null || true && \
    mkdir -p /home/agent && chown 1000:1000 /home/agent
USER 1000
WORKDIR /home/agent

EXPOSE 7681

ENTRYPOINT ["/entrypoint.sh"]
